# --- Мій пульт керування ---
alias nan='nano ~/.zshrc'
alias sou='source ~/.zshrc'
alias ss='~/dotfiles/bin/state/zen.sh'
alias lab='~/dotfiles/core/lab.sh'

# Система та чистка
alias c='clear'
alias c-lnx='lab clean'
alias c-win='lab win-clean'
alias clean-all='lab clean && lab win-clean'
alias ver='python3 --version && pip3 --version'

# Навігація та Провідник
alias win='explorer.exe .'
alias ..='cd ..'
alias ~='cd ~'
alias ll='ls -la'
alias C='cd /mnt/c/Users/maks_/'

# open = абракадабра xdg-open для всього
alias open='xdg-open'

# npm
alias run='npm run dev'
alias in='npm install'

# Git
alias cmt='git commit -am'
gpush() {
  git add .
  git commit -m "$1"
  git push
}

# Шпора
alias helpme='cat ~/dotfiles/aliases/general'
