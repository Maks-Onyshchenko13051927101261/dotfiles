# --- Мій пульт керування ---
alias nan='nano ~/.zshrc'
alias sou='source ~/.zshrc'
alias ss='~/dotfiles/bin/state/zen.sh'
alias lab='~/dotfiles/bin/lab.sh'

# Система та чистка
alias c='clear'
alias update='sudo apt update && sudo apt upgrade -y'
alias drop='sudo sh -c "echo 3 > /proc/sys/vm/drop_caches"'
alias clean_hist='rm ~/.zsh_history && history -c'
alias ver='python3 --version && pip3 --version'

# Навігація та Провідник
alias win='explorer.exe .'
alias ..='cd ..'
alias ~='cd ~'
alias ll='ls -la'
alias C='cd /mnt/c/Users/maks_/'

# . = швидке відкриття VS Code (Студії) в поточному місці
alias .='code .'

# open = абракадабра xdg-open для всього
alias open='xdg-open'

# Git (найходовіші)
alias gs='git status'
alias gcb='git checkout -b'
alias gcam='git commit -am'
alias gp='git push'

# npm
alias run='npm run dev'
alias in='npm install'

# Швидкий пуш: gpush "текст"
gpush() {
  git add .
  git commit -m "$1"
  git push
}

# Шпора
alias helpme='cat ~/dotfiles/commands.txt'
