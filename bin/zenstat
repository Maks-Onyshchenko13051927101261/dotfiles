#!/bin/bash
CORE_TEMP_PATH="/mnt/c/ProgramData/chocolatey/lib/coretemp/tools"
WEATHER_CACHE="/tmp/zenstat_weather"

# Очищуємо кеш при старті для свіжого запиту
echo "Wait..." > "$WEATHER_CACHE"

tput civis
trap "tput cnorm; rm -f $WEATHER_CACHE; clear; exit" INT TERM
clear

# База для мережі
A_RX=$(awk '/eth0/ {print $2}' /proc/net/dev)
A_TX=$(awk '/eth0/ {print $10}' /proc/net/dev)
MAX_RX=0; MAX_TX=0

# Функція форматування швидкості (твоя логіка + кольори)
format_speed() {
    local diff=$1
    local res=""
    if [ "$diff" -eq 0 ]; then res="0 B/s"
    elif [ "$diff" -lt 1024 ]; then res="${diff} B/s"
    elif [ "$diff" -lt 1048576 ]; then res="$((diff / 1024)) KB/s"
    else res="$((diff / 1024 / 1024)) MB/s"; fi
    
    if [ "$diff" -lt 1024 ]; then echo -ne "\033[0;32m$res\033[0m" # Зелений
    elif [ "$diff" -lt 1048576 ]; then echo -ne "\033[0;33m$res\033[0m" # Жовтий
    else echo -ne "\033[1;31m$res\033[0m"; fi # Червоний
}

while true; do
    # ПРЯМИЙ ЗАПИТ НА ГОСТОМЕЛЬ (Hostomel) з лімітом часу
    if [[ ! -f "$WEATHER_CACHE" || "$(cat "$WEATHER_CACHE")" == "Wait..." || $(find "$WEATHER_CACHE" -mmin +15) ]]; then
        (curl -s --max-time 5 "wttr.in/Hostomel?format=%c%t&m&lang=en" > "$WEATHER_CACHE" || echo "Offline" > "$WEATHER_CACHE") &
    fi
    WEATHER=$(cat "$WEATHER_CACHE" | head -n 1)

    tput cup 0 0
    TIME=$(date +"%H:%M:%S")

    # --- 1. ШАПКА ТА ПОГОДА ---
    echo -e "\033[0;36m--- ⛩️  ZENSTAT V9.9 | ⌚ $TIME ---\033[0m"
    echo -e "🕒 Up: $(uptime -p | sed 's/up //') "
    echo -e "🌍 Hostomel: \033[0;35m$WEATHER\033[0m"
    echo -e "\033[0;36m---------------------------------------\033[0m"

    # --- 2. CPU ТА RAM ---
    load=$(uptime | awk -F'average:' '{print $2}' | sed 's/^ //')
    mem=$(free -m | awk '/Mem:/ {printf "%d/%dMB", $3, $2}')
    echo -e "🧠 CPU: $load "
    echo -e "💾 RAM: $mem"

    # --- 3. ТЕМПЕРАТУРА ---
    LATEST_LOG=$(ls -t "$CORE_TEMP_PATH"/CT-Log*.csv 2>/dev/null | head -n 1)
    TEMP="??"
    if [ -n "$LATEST_LOG" ]; then
        VAL=$(tail -n 1 "$LATEST_LOG" | awk -F',' '{print $4}' | tr -d ' ')
        [[ $VAL =~ ^[0-9]+$ ]] && [ $VAL -gt 1000 ] && TEMP=$((VAL/1000)) || TEMP=$VAL
    fi
    echo -e "🌡️  Temp: \033[0;32m${TEMP}°C\033[0m"
    echo -e "\033[0;36m---------------------------------------\033[0m"

    # --- 4. ПРОЦЕСИ ---
    ps -eo comm,%cpu --sort=-%cpu | head -n 4 | tail -n 3 | awk '{printf "   %-15s %s%%\n", $1, $2}'
    echo -e "\033[0;36m---------------------------------------\033[0m"

    # --- 5. МЕРЕЖА (LIVE ТА MAX) ---
    B_RX=$(awk '/eth0/ {print $2}' /proc/net/dev); B_TX=$(awk '/eth0/ {print $10}' /proc/net/dev)
    D_RX=$((B_RX - A_RX)); D_TX=$((B_TX - A_TX))
    A_RX=$B_RX; A_TX=$B_TX
    
    [ "$D_RX" -gt "$MAX_RX" ] && MAX_RX=$D_RX
    [ "$D_TX" -gt "$MAX_TX" ] && MAX_TX=$D_TX

    echo -ne "🚀 LIVE  ⬇ " && format_speed $D_RX
    echo -ne "  |  ⬆ " && format_speed $D_TX
    echo -e "          "
    
    echo -e "\033[0;37m==============================\033[0m"
    
    echo -ne "🏅 MAX   ⬇ " && format_speed $MAX_RX
    echo -ne "  |  ⬆ " && format_speed $MAX_TX
    echo -e "          "
    echo -e "\033[0;36m---------------------------------------\033[0m"

    sleep 1
done
