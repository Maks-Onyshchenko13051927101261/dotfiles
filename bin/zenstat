#!/bin/bash

# Шлях до папки з логами (WSL формат)
CORE_TEMP_PATH="/mnt/c/ProgramData/chocolatey/lib/coretemp/tools"

# 1. Сховати курсор, щоб не миготів
tput civis

# 2. Повернути курсор назад при виході (Ctrl+C)
trap "tput cnorm; clear; exit" INT TERM

clear

while true; do
  # Повертаємо курсор в початок (0,0) для плавності
  tput cup 0 0
  
  # Отримуємо час (+2 години)
  TIME=$(date -d "+2 hours" +"%H:%M:%S")

  echo -e "\033[0;36m--- ⛩️  ZENSTAT V3.6 | ⌚ $TIME ---\033[0m"

  # Системна інфа
  UPTIME=$(uptime -p | sed 's/up //')
  IP_ADDR=$(hostname -I | awk '{print $1}')
  echo -e "🕒 Up: \033[0;32m$UPTIME\033[0m  🌐 IP: \033[0;32m$IP_ADDR\033[0m"
  echo -e "\033[0;36m---------------------------------------\033[0m"

  # CPU & RAM
  load=$(uptime | awk -F'load average:' '{ print $2 }' | sed 's/^ *//')
  mem=$(free -m | awk '/Mem:/ {print $3, $2}')
  used=$(echo $mem | cut -d' ' -f1)
  total=$(echo $mem | cut -d' ' -f2)
  percent=$((used * 100 / total))

  echo -e "🧠 CPU Load: $load"
  echo -e "💾 RAM: ${used}MB / ${total}MB (${percent}%)"

# 🌡️ ТЕМПЕРАТУРА 
  echo -ne "🌡️  Temp: "
  LATEST_LOG=$(ls -t "$CORE_TEMP_PATH"/CT-Log*.csv 2>/dev/null | head -n 1)

  if [ -n "$LATEST_LOG" ]; then
    # Беремо останню цифру. Якщо там 44000, ділимо на 1000
    raw_val=$(tail -n 1 "$LATEST_LOG" | awk -F',' '{print $4}' | tr -d ' ')
    
    if [[ $raw_val =~ ^[0-9]+$ ]]; then
      # Якщо число занадто велике, ділимо на 1000
      if [ "$raw_val" -gt 1000 ]; then
        temp_val=$((raw_val / 1000))
      else
        temp_val=$raw_val
      fi

      if [ "$temp_val" -lt 70 ]; then 
        echo -e "\033[0;32m${temp_val}°C (COOL)\033[0m"
      else 
        echo -e "\033[0;31m${temp_val}°C (HOT!)\033[0m"
      fi
    else
      echo -e "\033[1;33mSyncing...\033[0m"
    fi
  else
    echo -e "\033[1;31mLog not found\033[0m"
  fi

  # TOP Процеси
  echo -e "\033[0;33m📊 TOP PROCESSES:\033[0m"
  ps -eo comm,%cpu --sort=-%cpu | head -n 4 | tail -n 3 | awk '{printf "   %-15s %s%%\n", $1, $2}'
  echo -e "\033[0;36m---------------------------------------\033[0m"

  # Оновлення кожну секунду
  sleep 1
done
